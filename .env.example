# --- Vault output ---------------------------------------------------------
# Absolute host path to your wiki/Obsidian vault's raw/ folder.
# Example (Windows): C:\Users\you\Obsidian\MyVault\raw
# Example (Linux):   /home/you/vault/raw
VAULT_HOST_PATH=/absolute/path/to/your/vault/raw
# Subfolder inside raw/ where reels are written (grouped per creator handle)
INSTAGRAM_SUBDIR=instagram

# --- Transcription --------------------------------------------------------
# LOCAL = faster-whisper (offline, free) | API = OpenAI whisper-1
WHISPER_MODE=LOCAL
# tiny / base / small / medium / large-v3  (bigger = more accurate, slower)
WHISPER_MODEL=base
# int8 is fast & light on CPU; use float32 for best quality if you have RAM
WHISPER_COMPUTE_TYPE=int8
# Only needed when WHISPER_MODE=API
WHISPER_API_KEY=

# --- Source-specific ------------------------------------------------------
# YouTube: prefer existing subtitles, fall back to Whisper. Set true to also
# OCR on-screen text from video frames (slower, off by default).
YOUTUBE_OCR=false

# --- Optional: ngrok (Telegram -> n8n webhook; runs as a Docker service) ---
# Running ngrok in-container also avoids host antivirus TLS interception.
NGROK_AUTHTOKEN=
NGROK_DOMAIN=your-static-domain.ngrok-free.app
